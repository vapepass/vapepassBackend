PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vapepass
JWT_SECRET=change-me-in-production
JWT_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-in-production-too
JWT_REFRESH_EXPIRES=7d
CLIENT_URL=https://projectclient-zeta.vercel.app
NODE_ENV=production
# Comma-separated hostnames allowed to run the marketing-site demo chatbot
MARKETING_DEMO_HOSTS=projectclient-zeta.vercel.app

# Email (password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="VapePass <noreply@yourdomain.com>"
# Admin inbox for Free Setup Assistance notifications (falls back to ADMIN_EMAIL)
SUPPORT_ADMIN_EMAIL=admin@vapepass.com

# Stripe ($99/month subscription)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Optional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VapePass Assistant (AI chatbot)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SCRAPINGBEE_API_KEY=
CRON_SECRET=change-me-cron-secret
# Public API URL used in embed codes (no trailing slash)
API_PUBLIC_URL=http://localhost:5000
# Set true on long-running hosts to run daily inventory sync in-process
ENABLE_INTERNAL_CRON=false

# Optional — public HTTPS logo URL for emails (Gmail cannot load localhost/SVG)
# EMAIL_LOGO_URL=https://your-cdn.example.com/vapepass-logo.png

