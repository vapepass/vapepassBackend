PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vapepass
JWT_SECRET=change-me-in-production
JWT_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-in-production-too
JWT_REFRESH_EXPIRES=7d
CLIENT_URL=https://vapepass.vercel.app
NODE_ENV=production

# Email (password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="VapePass <noreply@yourdomain.com>"

# Stripe ($99/month subscription)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Optional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
